import("../packages/fard_aware/src/core/rng") as rng
import("../packages/fard_aware/src/tensor/ops") as tensor
import("../packages/fard_aware/src/replay/replay") as replay
import("../packages/fard_aware/src/receipt/encode") as receipt
import("../packages/fard_aware/src/trainer/state") as trainer_state
import("../packages/fard_aware/src/trainer/step") as trainer_step

fn make_transition(i, action_idx, reward) {
  let obs = tensor.make([4], [i * 1.0, i * 0.5, (i % 3) * 1.0, 1.0])
  let next_obs = tensor.make([4], [(i + 1) * 1.0, (i + 1) * 0.5, ((i + 1) % 3) * 1.0, 1.0])
  let action = tensor.onehot(3, action_idx)
  replay.transition(obs, action, reward, 1.0, next_obs, i)
}

test "rng deterministic" {
  let r0 = rng.make(9)
  let a = rng.next_float(r0)
  let b = rng.next_float(r0)
  a.value == b.value
}

test "receipt chain deterministic" {
  let p = receipt.payload("m", 1, ["a"], ["b"], "c", { state: 1 }, { state: 2 }, { ok: true })
  let r1 = receipt.step_receipt("sha256:genesis", p)
  let r2 = receipt.step_receipt("sha256:genesis", p)
  r1 == r2
}

test "trainer step increments" {
  let s0 = trainer_state.init(42, 5, 4, 4, 3, 11, 0.05)
  let rb0 = replay.empty(32)
  let rb1 = replay.append(rb0, make_transition(0, 0, 1.0))
  let rb2 = replay.append(rb1, make_transition(1, 1, 0.5))
  let s1 = trainer_step.step(s0, rb2)
  s1.step == 1
}

